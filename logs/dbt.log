  create view "neondb"."staging"."stg_trades__dbt_tmp"
    
    
  as (
    -- Staging: clean, typed, 1:1 with the source. No business logic here.
-- Rename to clear, consistent names and normalize the side value.

with source as (
    select * from "neondb"."raw"."trades"
)

