t,\n        row_number() over (\n            partition by product_id, minute\n            order by traded_at desc, trade_id desc\n        ) as rn_last\n    from base\n)\n\nselect\n    product_id,\n    minute,\n    max(price_usd) filter (where rn_first = 1)      as open_price,\n    max(price_usd)                                  as high_price,\n    min(price_usd)                                  as low_price,\n    max(price_usd) filter (where rn_last = 1)       as close_price,\n    sum(size)                                       as volume,\n    count(*)                                        as trade_count,\n    sum(price_usd * size) / nullif(sum(size), 0)    as vwap\nfrom ranked\ngroup by product_id, minute", "relation_name": "\"neondb\".\"marts\".\"agg_price_1m\"", "batch_results": null, "overload_results": null}, {"status": "pass", "timing": [{"name": "compile", "started_at": "2026-06-26T06:49:21.325444Z", "completed_at": "2026-06-26T06:49:21.338764Z"}, {"name": "execute", "started_at": "2026-06-26T06:49:21.339657Z", "completed_at": "2026-06-26T06:49:21.643083Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 0.3570435047149658, "adapter_response": {"_message": "SELECT 1", "code": "SELECT", "rows_affected": 1}, "message": null, "failures": 0, "unique_id": "test.crypto_analytics.dbt_utils_expression_is_true_agg_price_1m_high_price_low_price.142a65f327", "compiled": true, "compiled_code": "\n\n\n\nselect\n    1\nfrom \"neondb\".\"marts\".\"agg_price_1m\"\n\nwhere not(high_price >= low_price)\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "pass", "timing": [{"name": "compile", "started_at": "2026-06-26T06:49:21.316329Z", "completed_at": "2026-06-26T06:49:21.323908Z"}, {"name": "execute", "started_at": "2026-06-26T06:49:21.331506Z", "completed_at": "2026-06-26T06:49:21.657968Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.3810536861419678, "adapter_response": {"_message": "SELECT 1", "code": "SELECT", "rows