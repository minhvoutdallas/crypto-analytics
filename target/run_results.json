{"metadata": {"dbt_schema_version": "https://schemas.getdbt.com/dbt/run-results/v6.json", "dbt_version": "1.12.0b3", "generated_at": "2026-06-26T06:50:46.909113Z", "invocation_id": "6a2d44df-6f5d-4c3d-9fdf-4580ff3bf2ec", "invocation_started_at": "2026-06-26T06:50:45.278143Z", "env": {}}, "results": [{"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-26T06:50:46.753585Z", "completed_at": "2026-06-26T06:50:46.759315Z"}, {"name": "execute", "started_at": "2026-06-26T06:50:46.759576Z", "completed_at": "2026-06-26T06:50:46.759588Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.006654024124145508, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.crypto_analytics.stg_trades", "compiled": true, "compiled_code": "-- Staging: clean, typed, 1:1 with the source. No business logic here.\n-- Rename to clear, consistent names and normalize the side value.\n\nwith source as (\n    select * from \"neondb\".\"raw\".\"trades\"\n)\n\nselect\n    product_id,\n    trade_id,\n    price::numeric          as price_usd,    -- quote currency is USD for our products\n    size::numeric           as size,\n    lower(side)             as side,         -- normalize to lowercase buy/sell\n    ts::timestamptz         as traded_at,    -- event time\n    ingested_at                              -- load time (used for incremental + freshness)\nfrom source", "relation_name": "\"neondb\".\"staging\".\"stg_trades\"", "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-26T06:50:46.771522Z", "completed_at": "2026-06-26T06:50:46.787777Z"}, {"name": "execute", "started_at": "2026-06-26T06:50:46.788213Z", "completed_at": "2026-06-26T06:50:46.788223Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.017456769943237305, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.crypto_analytics.dim_products", "compiled": true, "compiled_code": "-- Dimension: one row per traded market. Derived from observed products so it\n-- grows automatically when the collector starts tracking a new pair.\n\nwith products as (\n    select distinct product_id\n    from \"neondb\".\"staging\".\"stg_trades\"\n)\n\nselect\n    product_id,\n    split_part(product_id, '-', 1)      as base_currency,   -- e.g. BTC\n    split_part(product_id, '-', 2)      as quote_currency,  -- e.g. USD\n    replace(product_id, '-', ' / ')     as display_name     -- e.g. BTC / USD\nfrom products", "relation_name": "\"neondb\".\"marts\".\"dim_products\"", "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-26T06:50:46.774311Z", "completed_at": "2026-06-26T06:50:46.790165Z"}, {"name": "execute", "started_at": "2026-06-26T06:50:46.796871Z", "completed_at": "2026-06-26T06:50:46.796876Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.026378631591796875, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.crypto_analytics.dbt_utils_unique_combination_of_columns_stg_trades_product_id__trade_id.1ee3149b9a", "compiled": true, "compiled_code": "\n\n\n\n\n\nwith validation_errors as (\n\n    select\n        product_id, trade_id\n    from \"neondb\".\"staging\".\"stg_trades\"\n    group by product_id, trade_id\n    having count(*) > 1\n\n)\n\nselect *\nfrom validation_errors\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-26T06:50:46.762354Z", "completed_at": "2026-06-26T06:50:46.789076Z"}, {"name": "execute", "started_at": "2026-06-26T06:50:46.796319Z", "completed_at": "2026-06-26T06:50:46.796326Z"}], "thread_id": "Thread-4 (worker)", "execution_time": 0.03537940979003906, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.crypto_analytics.accepted_values_stg_trades_side__buy__sell.920e8a1306", "compiled": true, "compiled_code": "\n    \n    \n\nwith all_values as (\n\n    select\n        side as value_field,\n        count(*) as n_records\n\n    from \"neondb\".\"staging\".\"stg_trades\"\n    group by side\n\n)\n\nselect *\nfrom all_values\nwhere value_field not in (\n    'buy','sell'\n)\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-26T06:50:46.781386Z", "completed_at": "2026-06-26T06:50:46.797796Z"}, {"name": "execute", "started_at": "2026-06-26T06:50:46.802047Z", "completed_at": "2026-06-26T06:50:46.802052Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 0.03193330764770508, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.crypto_analytics.fct_trades", "compiled": true, "compiled_code": "-- Fact: the grain is one trade. Incremental so each run only transforms NEW\n-- trades instead of rebuilding the full history every time.\n--\n-- delete+insert with a composite unique_key makes re-runs safe: if a trade ever\n-- reappears in the incoming slice, its old row is replaced rather than doubled.\n\n\n\nselect\n    product_id,\n    trade_id,\n    price_usd,\n    size,\n    side,\n    traded_at,\n    ingested_at\nfrom \"neondb\".\"staging\".\"stg_trades\"\n\n\n    -- Only pull rows loaded after the newest row we already have.\n    -- coalesce handles the very first incremental run (table exists but is empty).\n    where ingested_at > (select coalesce(max(ingested_at), '2000-01-01'::timestamptz) from \"neondb\".\"marts\".\"fct_trades\")\n", "relation_name": "\"neondb\".\"marts\".\"fct_trades\"", "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-26T06:50:46.790462Z", "completed_at": "2026-06-26T06:50:46.798431Z"}, {"name": "execute", "started_at": "2026-06-26T06:50:46.801539Z", "completed_at": "2026-06-26T06:50:46.801545Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.012148380279541016, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.crypto_analytics.not_null_stg_trades_price_usd.5307aeb400", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect price_usd\nfrom \"neondb\".\"staging\".\"stg_trades\"\nwhere price_usd is null\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-26T06:50:46.798691Z", "completed_at": "2026-06-26T06:50:46.807159Z"}, {"name": "execute", "started_at": "2026-06-26T06:50:46.810019Z", "completed_at": "2026-06-26T06:50:46.810024Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.012540578842163086, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.crypto_analytics.not_null_stg_trades_product_id.ee08461d11", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect product_id\nfrom \"neondb\".\"staging\".\"stg_trades\"\nwhere product_id is null\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-26T06:50:46.807724Z", "completed_at": "2026-06-26T06:50:46.814037Z"}, {"name": "execute", "started_at": "2026-06-26T06:50:46.816918Z", "completed_at": "2026-06-26T06:50:46.816923Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.012723684310913086, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.crypto_analytics.not_null_stg_trades_traded_at.62bfcc51ca", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect traded_at\nfrom \"neondb\".\"staging\".\"stg_trades\"\nwhere traded_at is null\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-26T06:50:46.804902Z", "completed_at": "2026-06-26T06:50:46.818034Z"}, {"name": "execute", "started_at": "2026-06-26T06:50:46.821748Z", "completed_at": "2026-06-26T06:50:46.821754Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 0.01905083656311035, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.crypto_analytics.not_null_stg_trades_trade_id.f81937320b", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect trade_id\nfrom \"neondb\".\"staging\".\"stg_trades\"\nwhere trade_id is null\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-26T06:50:46.814323Z", "completed_at": "2026-06-26T06:50:46.821465Z"}, {"name": "execute", "started_at": "2026-06-26T06:50:46.823359Z", "completed_at": "2026-06-26T06:50:46.823364Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.009981870651245117, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.crypto_analytics.not_null_dim_products_base_currency.5acdd6bf2b", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect base_currency\nfrom \"neondb\".\"marts\".\"dim_products\"\nwhere base_currency is null\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-26T06:50:46.810561Z", "completed_at": "2026-06-26T06:50:46.822516Z"}, {"name": "execute", "started_at": "2026-06-26T06:50:46.824573Z", "completed_at": "2026-06-26T06:50:46.824579Z"}], "thread_id": "Thread-4 (worker)", "execution_time": 0.021054983139038086, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.crypto_analytics.not_null_stg_trades_size.e495507d52", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect size\nfrom \"neondb\".\"staging\".\"stg_trades\"\nwhere size is null\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-26T06:50:46.818676Z", "completed_at": "2026-06-26T06:50:46.824061Z"}, {"name": "execute", "started_at": "2026-06-26T06:50:46.827906Z", "completed_at": "2026-06-26T06:50:46.827912Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.010232686996459961, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.crypto_analytics.not_null_dim_products_product_id.c8aba288d1", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect product_id\nfrom \"neondb\".\"marts\".\"dim_products\"\nwhere product_id is null\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-26T06:50:46.825424Z", "completed_at": "2026-06-26T06:50:46.835589Z"}, {"name": "execute", "started_at": "2026-06-26T06:50:46.835952Z", "completed_at": "2026-06-26T06:50:46.835957Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 0.013218879699707031, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.crypto_analytics.not_null_dim_products_quote_currency.11b79ed469", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect quote_currency\nfrom \"neondb\".\"marts\".\"dim_products\"\nwhere quote_currency is null\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-26T06:50:46.829030Z", "completed_at": "2026-06-26T06:50:46.836395Z"}, {"name": "execute", "started_at": "2026-06-26T06:50:46.839562Z", "completed_at": "2026-06-26T06:50:46.839568Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.015334367752075195, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.crypto_analytics.unique_dim_products_product_id.ef7b2a9985", "compiled": true, "compiled_code": "\n    \n    \n\nselect\n    product_id as unique_field,\n    count(*) as n_records\n\nfrom \"neondb\".\"marts\".\"dim_products\"\nwhere product_id is not null\ngroup by product_id\nhaving count(*) > 1\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-26T06:50:46.833632Z", "completed_at": "2026-06-26T06:50:46.840439Z"}, {"name": "execute", "started_at": "2026-06-26T06:50:46.844815Z", "completed_at": "2026-06-26T06:50:46.844820Z"}], "thread_id": "Thread-4 (worker)", "execution_time": 0.016440629959106445, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.crypto_analytics.agg_price_1m", "compiled": true, "compiled_code": "-- Aggregate: 1-minute OHLCV candles per product \u2014 the headline metric for the\n-- dashboard. Open/close are the first/last trade price within each minute\n-- (ordered by event time, tie-broken by trade_id); high/low/volume are simple\n-- aggregates. VWAP is the volume-weighted average price.\n\nwith base as (\n    select\n        product_id,\n        date_trunc('minute', traded_at) as minute,\n        trade_id,\n        price_usd,\n        size,\n        traded_at\n    from \"neondb\".\"marts\".\"fct_trades\"\n),\n\nranked as (\n    select\n        *,\n        row_number() over (\n            partition by product_id, minute\n            order by traded_at asc, trade_id asc\n        ) as rn_first,\n        row_number() over (\n            partition by product_id, minute\n            order by traded_at desc, trade_id desc\n        ) as rn_last\n    from base\n)\n\nselect\n    product_id,\n    minute,\n    max(price_usd) filter (where rn_first = 1)      as open_price,\n    max(price_usd)                                  as high_price,\n    min(price_usd)                                  as low_price,\n    max(price_usd) filter (where rn_last = 1)       as close_price,\n    sum(size)                                       as volume,\n    count(*)                                        as trade_count,\n    sum(price_usd * size) / nullif(sum(size), 0)    as vwap\nfrom ranked\ngroup by product_id, minute", "relation_name": "\"neondb\".\"marts\".\"agg_price_1m\"", "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-26T06:50:46.837172Z", "completed_at": "2026-06-26T06:50:46.841300Z"}, {"name": "execute", "started_at": "2026-06-26T06:50:46.844384Z", "completed_at": "2026-06-26T06:50:46.844388Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.007797956466674805, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.crypto_analytics.accepted_values_fct_trades_side__buy__sell.e38e52885b", "compiled": true, "compiled_code": "\n    \n    \n\nwith all_values as (\n\n    select\n        side as value_field,\n        count(*) as n_records\n\n    from \"neondb\".\"marts\".\"fct_trades\"\n    group by side\n\n)\n\nselect *\nfrom all_values\nwhere value_field not in (\n    'buy','sell'\n)\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-26T06:50:46.841602Z", "completed_at": "2026-06-26T06:50:46.850248Z"}, {"name": "execute", "started_at": "2026-06-26T06:50:46.855937Z", "completed_at": "2026-06-26T06:50:46.855943Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 0.015307903289794922, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.crypto_analytics.dbt_utils_unique_combination_of_columns_fct_trades_product_id__trade_id.7339480ee9", "compiled": true, "compiled_code": "\n\n\n\n\n\nwith validation_errors as (\n\n    select\n        product_id, trade_id\n    from \"neondb\".\"marts\".\"fct_trades\"\n    group by product_id, trade_id\n    having count(*) > 1\n\n)\n\nselect *\nfrom validation_errors\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-26T06:50:46.850484Z", "completed_at": "2026-06-26T06:50:46.857005Z"}, {"name": "execute", "started_at": "2026-